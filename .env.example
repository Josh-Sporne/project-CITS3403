# Required — must be set to a long random string before first run.
# The app refuses to boot if this is empty, forcing you to pick a real value.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Required — points Flask CLI at the app entrypoint (run.py).
# Without this, `flask db upgrade` and `flask run` will print
# "Could not locate a Flask application".
FLASK_APP=run.py

# Optional — defaults to a SQLite file in the project folder if unset.
DATABASE_URL=sqlite:///app.db

# Optional — only needed if you want the Pantry AI "Generate with AI"
# button to actually call OpenAI. Without a real key it falls back to
# local pantry matching only.
OPENAI_API_KEY=sk-your-key-here

# Optional — only needed if you want Pantry AI suggestions to ship with
# stock food photos (otherwise a placeholder is used).
PEXELS_API_KEY=
